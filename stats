local labelDist = Instance.new("TextLabel")
labelDist.Size = UDim2.new(1, -8, 1, 0)
labelDist.Position = UDim2.new(0, 4, 0, 0)
labelDist.BackgroundTransparency = 1
labelDist.TextColor3 = Color3.new(1, 1, 1)
labelDist.TextSize = 13
labelDist.Font = Enum.Font.GothamSemibold
labelDist.TextXAlignment = Enum.TextXAlignment.Left
labelDist.Text = "Ayuwoki: -- studs"
labelDist.Parent = frameDist

game.ReplicatedStorage.Values.Timer:GetPropertyChangedSignal("Value"):Connect(function()
    if game.ReplicatedStorage.Values.Day.Value == true then
        labelTimer.Text = game.ReplicatedStorage.Values.Timer.Value .. " sec until night"
    else
        labelTimer.Text = game.ReplicatedStorage.Values.Timer.Value .. " sec until day"
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    local ayuwoki = game.Workspace:FindFirstChild("Ayuwoki")
    if ayuwoki and game.Players.LocalPlayer.Character then
        local dist = (ayuwoki:GetBoundingBox().Position - game.Players.LocalPlayer.Character:GetBoundingBox().Position).Magnitude
        labelDist.Text = "Ayuwoki: " .. math.round(dist) .. " studs"
    else
        labelDist.Text = "Ayuwoki: gone"
    end
end)
